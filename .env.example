# Root directory to scan recursively for Calibre libraries
CALIBRE_ROOT=/volume1/books

# Optional container user/group mapping for Compose deployments
PUID=1000
PGID=1000

# Server bind
HOST=0.0.0.0
PORT=8787

# Public URL used in OPDS links
BASE_URL=http://localhost:8787

# Feed size and refresh interval
FEED_LIMIT=100
REFRESH_MS=600000

# Optional basic auth for OPDS/HTML routes
# BASIC_AUTH_USER=reader
# BASIC_AUTH_PASS=secret

# KOReader sync database path (defaults to $CALIBRE_ROOT/koreader.db)
# KOSYNC_DB_PATH=/volume1/books/koreader.db
